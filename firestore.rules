
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic rule: User must be authenticated for most operations
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Visitors sub-collection
      match /visitors/{visitorId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null;
      }

      // AI Recommendations sub-collection
      match /aiRecommendations/{recommendationId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Chat Rooms Rules
    match /chatRooms/{chatRoomId} {
      // Allow reading if the user is a participant. Works for 'get' and 'list' with correct queries.
      allow read: if request.auth != null && (request.auth.uid in resource.data.participantIds);
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid in resource.data.participantIds);
      allow delete: if false; // Chats are usually permanent

      match /messages/{messageId} {
        // Broad read for messages within authorized chats for simplicity in MVP
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }

    // Call Records Rules
    match /calls/{callId} {
      // Allow reading if the user is a participant. 
      // This supports the 'array-contains' query in the app.
      allow read: if request.auth != null && (request.auth.uid in resource.data.participantIds);
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid in resource.data.participantIds);
      allow delete: if false;
    }

    // Transactions Rules
    match /transactions/{transactionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
