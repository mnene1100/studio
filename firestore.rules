
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if the user is an admin
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /users/{userId} {
      allow read: if true;
      // Allow users to update their own profile, but NOT critical financial fields
      allow update: if request.auth != null && request.auth.uid == userId 
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance', 'earnings', 'isAdmin', 'isCoinSeller', 'isSupport']);
      // Allow admins to do anything
      allow write: if request.auth != null && isAdmin();
      
      match /visitors/{visitorId} {
        allow read, write: if request.auth != null;
      }
    }

    match /chatRooms/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null;
      
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    match /calls/{callId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow write: if request.auth != null;
    }

    match /transactions/{transId} {
      // Users can see their own history, but only the system (Admin/Server) can write
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
      allow update, delete: if false; 
    }
  }
}
