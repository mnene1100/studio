rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if the user is an admin
    function isAdmin() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /users/{userId} {
      allow read: if true;
      
      // Allow users to create their own profile during onboarding
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Allow users to update their own profile, but NOT critical financial or role fields
      allow update: if request.auth != null && request.auth.uid == userId 
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance', 'earnings', 'isAdmin', 'isCoinSeller', 'isSupport']);
      
      // Allow admins to do anything (including updating balance and deleting)
      allow write: if request.auth != null && isAdmin();
      
      match /visitors/{visitorId} {
        allow read, write: if request.auth != null;
      }
      
      match /aiRecommendations/{recId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // System only
      }
    }

    match /chatRooms/{chatId} {
      allow read, write: if request.auth != null && (request.auth.uid in resource.data.participantIds);
      allow create: if request.auth != null;
      
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    match /calls/{callId} {
      // Allow reading if the user is a participant or the caller
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.callerId || 
        request.auth.uid in resource.data.participantIds
      );
      // Allow creation by any authenticated user
      allow create: if request.auth != null;
      // Allow updates by participants (to change status/endTime)
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.callerId || 
        request.auth.uid in resource.data.participantIds
      );
    }

    match /transactions/{transId} {
      // Users can see their own history
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.senderId);
      allow create: if request.auth != null; 
      allow update, delete: if false; 
    }
  }
}