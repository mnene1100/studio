rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEXO PROTOTYPE SECURITY RULES - FULLY OPEN
     * 
     * These rules allow anyone (even unauthenticated users) to read and write.
     * Use this ONLY for rapid prototyping.
     */

    match /{document=**} {
      allow read, write: if true;
    }
  }
}