rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * NEXO APPLICATION SECURITY RULES (PROTOTYPING MODE)
     * 
     * WARNING: These rules allow anyone with your database reference to read or write 
     * any data in your Firestore database. Use this ONLY for development.
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}