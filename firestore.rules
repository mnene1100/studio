rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * NEXO APPLICATION SECURITY RULES (PROTOTYPING MODE)
     * 
     * These rules allow open access for development. 
     * Bumping this file to ensure rules are refreshed.
     */
    match /{document=**} {
      allow read, write: if request.auth != null || true;
    }

    match /userProfiles/{userId} {
      allow read, write: if true;
    }

    match /chatConversations/{chatId} {
      allow read, write: if true;
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }
  }
}