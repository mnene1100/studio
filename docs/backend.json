
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information within the NEXO application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "numericId": {
          "type": "string",
          "description": "A unique 7-9 digit numeric ID assigned to the user."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "displayName": {
          "type": "string",
          "description": "The name chosen by the user."
        },
        "gender": {
          "type": "string",
          "description": "The user's gender.",
          "enum": ["Male", "Female"]
        },
        "dob": {
          "type": "string",
          "description": "Date of birth.",
          "format": "date"
        },
        "country": {
          "type": "string",
          "description": "The user's country of residence (restricted to East Africa)."
        },
        "profilePictureUrl": {
          "type": "string",
          "description": "URL to the user's profile picture.",
          "format": "uri"
        },
        "statusMessage": {
          "type": "string",
          "description": "A custom status message."
        },
        "balance": {
          "type": "number",
          "description": "The user's current coin balance."
        },
        "earnings": {
          "type": "number",
          "description": "The user's total earnings."
        },
        "isVerified": {
          "type": "boolean",
          "description": "Whether the user's profile is verified."
        },
        "lastOnlineAt": {
          "type": "string",
          "description": "Timestamp indicating the last time the user was online.",
          "format": "date-time"
        },
        "lastCheckedVisitorsAt": {
          "type": "string",
          "description": "Timestamp when the user last checked their visitors list.",
          "format": "date-time"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user profile was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "numericId",
        "email",
        "displayName",
        "gender",
        "dob",
        "country",
        "createdAt"
      ]
    },
    "ProfileVisitor": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ProfileVisitor",
      "type": "object",
      "description": "Represents a user who visited another user's profile.",
      "properties": {
        "id": { "type": "string" },
        "visitorId": { "type": "string" },
        "visitedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "visitorId", "visitedAt"]
    },
    "ChatConversation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ChatConversation",
      "type": "object",
      "description": "Represents a single chat conversation.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the ChatConversation entity."
        },
        "type": {
          "type": "string",
          "description": "The type of the chat conversation."
        },
        "participantIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lastMessageSentAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the last sent message."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "type",
        "participantIds",
        "createdAt",
        "updatedAt"
      ]
    },
    "Message": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Message",
      "type": "object",
      "description": "Represents a single message sent within a chat.",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "sentAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string" }
      },
      "required": ["id", "chatId", "senderId", "content", "sentAt", "type"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores individual user profile information."
        }
      },
      {
        "path": "/userProfiles/{userId}/visitors/{visitorId}",
        "definition": {
          "entityName": "ProfileVisitor",
          "schema": {
            "$ref": "#/backend/entities/ProfileVisitor"
          },
          "description": "Stores profile visitor information."
        }
      },
      {
        "path": "/chatConversations/{chatId}",
        "definition": {
          "entityName": "ChatConversation",
          "schema": {
            "$ref": "#/backend/entities/ChatConversation"
          },
          "description": "Represents a chat conversation."
        }
      },
      {
        "path": "/chatConversations/{chatId}/messages/{messageId}",
        "definition": {
          "entityName": "Message",
          "schema": {
            "$ref": "#/backend/entities/Message"
          },
          "description": "Stores individual messages."
        }
      }
    ]
  }
}
