{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile within the NEXO application, including personal details, contact information, and status.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "numericId": {
          "type": "string",
          "description": "A unique 7-9 digit numeric ID assigned to the user during onboarding, displayed on their 'Me' screen."
        },
        "displayName": {
          "type": "string",
          "description": "The user's chosen display name or alias within the application."
        },
        "email": {
          "type": "string",
          "description": "The user's email address, used for identification and contact purposes.",
          "format": "email"
        },
        "profilePictureUrl": {
          "type": "string",
          "description": "URL to the user's profile image or avatar.",
          "format": "uri"
        },
        "statusMessage": {
          "type": "string",
          "description": "A short biographical description provided by the user."
        },
        "gender": {
          "type": "string",
          "enum": ["Male", "Female"]
        },
        "dob": {
          "type": "string",
          "format": "date"
        },
        "country": {
          "type": "string"
        },
        "balance": {
          "type": "number",
          "description": "Current NX coin balance."
        },
        "earnings": {
          "type": "number",
          "description": "Current diamond earnings."
        },
        "lastOnlineAt": {
          "type": "string",
          "format": "date-time"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "isAdmin": {
          "type": "boolean"
        },
        "isCoinSeller": {
          "type": "boolean"
        },
        "isSupport": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "numericId",
        "displayName",
        "email",
        "createdAt"
      ]
    },
    "ChatRoom": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ChatRoom",
      "type": "object",
      "description": "Represents a single conversation thread.",
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["private", "group"]
        },
        "participantIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lastMessageContent": {
          "type": "string"
        },
        "lastMessageSentAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "unreadCounts": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        }
      },
      "required": [
        "id",
        "type",
        "participantIds"
      ]
    },
    "Message": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Message",
      "type": "object",
      "description": "Represents a single message sent within a ChatRoom.",
      "properties": {
        "id": {
          "type": "string"
        },
        "chatId": {
          "type": "string"
        },
        "senderId": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "sentAt": {
          "type": "string",
          "format": "date-time"
        },
        "type": {
          "type": "string",
          "enum": ["text", "image", "voice"]
        }
      },
      "required": [
        "chatId",
        "senderId",
        "content",
        "sentAt"
      ]
    },
    "Call": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Call",
      "type": "object",
      "description": "Represents a record of a voice or video call.",
      "properties": {
        "id": {
          "type": "string"
        },
        "callerId": {
          "type": "string"
        },
        "participantIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "type": {
          "type": "string",
          "enum": ["voice", "video"]
        },
        "startTime": {
          "type": "string",
          "format": "date-time"
        },
        "endTime": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string"
        },
        "durationSeconds": {
          "type": "number"
        }
      },
      "required": [
        "callerId",
        "participantIds",
        "type",
        "startTime"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "/chatRooms/{chatRoomId}",
        "definition": {
          "entityName": "ChatRoom",
          "schema": {
            "$ref": "#/backend/entities/ChatRoom"
          },
          "description": "Represents individual chat conversations."
        }
      },
      {
        "path": "/chatRooms/{chatRoomId}/messages/{messageId}",
        "definition": {
          "entityName": "Message",
          "schema": {
            "$ref": "#/backend/entities/Message"
          },
          "description": "Stores individual messages within a specific chat room."
        }
      },
      {
        "path": "/calls/{callId}",
        "definition": {
          "entityName": "Call",
          "schema": {
            "$ref": "#/backend/entities/Call"
          },
          "description": "Records details of voice or video calls."
        }
      },
      {
        "path": "/transactions/{transId}",
        "definition": {
          "entityName": "Transaction",
          "schema": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "coins": { "type": "number" },
              "type": { "type": "string" },
              "status": { "type": "string" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          },
          "description": "Stores financial transactions for wallet tracking."
        }
      }
    ]
  }
}
